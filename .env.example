# ==========================================
# EduPlay SaaS — Environment Variables Guide
# ==========================================
# Copy this file to .env and fill in real values.
# Never commit .env to git.

# ── Database (Neon Serverless Postgres) ───────────────────────────────────────
# For PRODUCTION: append ?pgbouncer=true&connection_limit=1 to prevent
# Prisma from opening too many connections on serverless.
# This is the #1 scale fix — unblocks 50k+ concurrent users.
DATABASE_URL="postgresql://USER:PASSWORD@ep-XXXX.us-east-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connection_limit=1"

# Direct URL bypasses PgBouncer — required by Prisma for migrations.
DIRECT_URL="postgresql://USER:PASSWORD@ep-XXXX.us-east-1.aws.neon.tech/neondb?sslmode=require"

# ── Auth (NextAuth) ───────────────────────────────────────────────────────────
NEXTAUTH_URL="https://app.eduplay.in"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Google OAuth (for teacher/student sign-in)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ── Redis (Upstash) ────────────────────────────────────────────────────────────
# Used for: rate limiting, leaderboard sorted sets, session caching
UPSTASH_REDIS_REST_URL="https://XXX.upstash.io"
UPSTASH_REDIS_REST_TOKEN=""

# ── Email (Resend) ─────────────────────────────────────────────────────────────
RESEND_API_KEY="re_XXXX"
EMAIL_FROM="EduPlay <noreply@eduplay.in>"

# ── Payments (Razorpay) ────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# ── Cron Jobs ─────────────────────────────────────────────────────────────────
# All cron routes require this secret in Authorization: Bearer <CRON_SECRET>
CRON_SECRET="generate-with-openssl-rand-hex-32"

# ── Error Tracking (Sentry) ───────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""
SENTRY_ORG=""
SENTRY_PROJECT=""

# ── App URLs ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://app.eduplay.in"

# ── Feature Flags ─────────────────────────────────────────────────────────────
# Set to "true" to enable advanced analytics for school admin users
FEATURE_ANALYTICS="true"

# ── Vercel / Railway ──────────────────────────────────────────────────────────
# Auto-set by Vercel — used in health check endpoint
# VERCEL_REGION="iad1"
