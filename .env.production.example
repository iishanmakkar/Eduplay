# Environment Variables Example 
# For reference on production deployment platforms (Vercel/Railway)

# Required Database Connection URLs
DATABASE_URL="postgres://user:password@neon.tech:5432/db"
DATABASE_POOL_URL="postgres://user:password@neon.tech:5432/db?pgbouncer=true"
DATABASE_READONLY_URL="postgres://rep_user:password@neon.tech:5432/db"

# Redis cache target
REDIS_URL="redis://default:password@upstash.io:6379"

# Providers
OPENROUTER_API_KEY="sk-or-v1-xxxxxxxxxxxxxxxxx"

# Security Configurations
NEXTAUTH_SECRET="secure_random_base64_string_length_32+"
NEXTAUTH_URL="https://eduplay-saas.production.app"
CRON_SECRET="another_secure_long_random_string_for_vercel_cron"

# Financial Governance
AI_COST_MONTHLY_LIMIT_DEFAULT=5
AI_COST_MONTHLY_LIMIT_PRO=100
AI_COST_MONTHLY_LIMIT_ENTERPRISE=500
