// Analytics and Tracking Models

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  schoolId  String?
  school    School?  @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  eventType String   // page_view, game_play, signup, login, etc.
  eventData Json?    // Additional event-specific data
  createdAt DateTime @default(now())
  
  @@index([eventType, createdAt])
  @@index([schoolId, createdAt])
  @@index([userId, createdAt])
}

model DailyMetrics {
  id                String   @id @default(cuid())
  date              DateTime @unique
  totalUsers        Int      @default(0)
  activeUsers       Int      @default(0)
  newSignups        Int      @default(0)
  gamesPlayed       Int      @default(0)
  revenue           Float    @default(0)
  trialConversions  Int      @default(0)
  churnedUsers      Int      @default(0)
  avgSessionTime    Int      @default(0) // in seconds
  
  @@index([date])
}

model UsageMetric {
  id        String   @id @default(cuid())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  date      DateTime
  students  Int      @default(0)
  teachers  Int      @default(0)
  games     Int      @default(0)
  
  @@unique([schoolId, date])
  @@index([schoolId, date])
}
