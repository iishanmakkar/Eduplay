// Prisma Schema for EduPlay SaaS Platform
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  STUDENT
  TEACHER
  SCHOOL
  OWNER
  INDEPENDENT
}

enum ConsentStatus {
  NOT_REQUIRED // Adults / Users >= 13
  PENDING // Under 13, awaiting parent verification
  APPROVED // Under 13, parent verified
  REJECTED // Under 13, parent denied
}

enum SubscriptionPlan {
  STARTER
  SCHOOL
  DISTRICT
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
}

